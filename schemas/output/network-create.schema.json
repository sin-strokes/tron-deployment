{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tronprotocol/tron-deployment/blob/master/schemas/output/network-create.schema.json",
  "title": "trond network create output",
  "type": "object",
  "required": ["network", "nodes"],
  "properties": {
    "network": { "type": "string", "description": "The intent's `name:` — used as the network identifier." },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name":      { "type": "string", "description": "Container name. Format: <network>-node<index>." },
          "type":      { "type": "string", "enum": ["fullnode", "witness", "solidity", "lite"] },
          "endpoints": { "type": "object", "additionalProperties": { "type": "string" } },
          "ready":     { "type": "boolean" },
          "error":     { "type": "string", "description": "Present only when this node failed to deploy; sibling nodes are still attempted." }
        }
      }
    }
  }
}
