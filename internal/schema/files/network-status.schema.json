{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tronprotocol/tron-deployment/blob/master/schemas/output/network-status.schema.json",
  "title": "trond network status output",
  "description": "Flat array of managed network nodes (those whose name contains `-node`). Always an array, never null — empty when no network is deployed.",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["name", "status"],
    "properties": {
      "name":     { "type": "string", "description": "Container name (e.g. private-dev-node0)." },
      "status":   { "type": "string", "enum": ["running", "stopped", "starting", "unknown"] },
      "runtime":  { "type": "string", "enum": ["docker", "jar"] },
      "version":  { "type": "string" },
      "type":     { "type": "string", "enum": ["fullnode", "witness", "solidity", "lite"] }
    }
  }
}
