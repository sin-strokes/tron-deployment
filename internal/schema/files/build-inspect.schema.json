{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tronprotocol/tron-deployment/blob/master/schemas/output/build-inspect.schema.json",
  "title": "trond build inspect output",
  "description": "Returned by `trond build inspect <cache-key> -o json`. Identical to a single entry from `trond build list`'s entries array. On NOT_FOUND or AMBIGUOUS_PREFIX the error envelope (schemas/output/error.schema.json) is emitted instead.",
  "type": "object",
  "required": [
    "cache_key",
    "source_revision",
    "dirty",
    "artifact_kind",
    "builder_image",
    "jdk_version",
    "gradle_task",
    "builder",
    "duration_ms",
    "created_at",
    "size_bytes",
    "orphaned"
  ],
  "properties": {
    "cache_key":           { "type": "string" },
    "source_path":         { "type": "string" },
    "source_revision":     { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "patch_hash":          { "type": "string" },
    "dirty":               { "type": "boolean" },
    "builder_image":       { "type": "string" },
    "builder_image_digest":{ "type": "string" },
    "jdk_version":         { "type": "string", "enum": ["8","11","17","21"] },
    "artifact_kind":       { "type": "string", "enum": ["jar","image"] },
    "artifact_path":       { "type": "string" },
    "image_tag":           { "type": "string" },
    "image_id":            { "type": "string" },
    "sha256":              { "type": "string" },
    "gradle_task":         { "type": "string" },
    "gradle_args":         { "type": "array", "items": { "type": "string" } },
    "builder":             { "type": "string", "enum": ["docker","host"] },
    "platform":            { "type": "string" },
    "duration_ms":         { "type": "integer", "minimum": 0 },
    "created_at":          { "type": "string", "format": "date-time" },
    "size_bytes":          { "type": "integer", "minimum": 0 },
    "orphaned":            { "type": "boolean" }
  }
}
