# Slim runtime image for trond. The binary is fully static (CGO_ENABLED=0)
# so we ship it on alpine — small, has /bin/sh for users who want to exec
# in, and ships ca-certificates needed for `version --check-update` and
# any future HTTPS calls.
FROM alpine:3.20

RUN apk add --no-cache ca-certificates docker-cli openssh-client \
    && adduser -D -u 1000 trond

# trond does not require root for its own state, but operating on docker
# from inside the container needs the host's docker socket bind-mounted.
# Document via VOLUME and the official entrypoint shows a hint when run
# without it.
VOLUME ["/home/trond/.trond"]

COPY trond /usr/local/bin/trond

USER trond
WORKDIR /home/trond

ENTRYPOINT ["/usr/local/bin/trond"]
CMD ["--help"]
